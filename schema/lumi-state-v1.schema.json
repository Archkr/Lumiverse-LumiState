{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Archkr/Lumiverse-LumiState/schema/lumi-state-v1.schema.json",
  "title": "LumiState Snapshot v1",
  "type": "object",
  "required": [
    "protocol",
    "schemaVersion",
    "source",
    "chatId",
    "revision",
    "freshness",
    "generatedAt",
    "updatedAt",
    "visibility",
    "state"
  ],
  "properties": {
    "protocol": { "const": "lumi_state.v1" },
    "schemaVersion": { "const": 1 },
    "source": {
      "type": "object",
      "required": ["extensionId", "extensionVersion", "endpoint"],
      "properties": {
        "extensionId": { "type": "string", "minLength": 1 },
        "extensionVersion": { "type": "string", "minLength": 1 },
        "endpoint": { "type": "string", "minLength": 3 }
      },
      "additionalProperties": false
    },
    "chatId": { "type": ["string", "null"] },
    "revision": { "type": "integer", "minimum": 0 },
    "freshness": { "enum": ["fresh", "stale", "unavailable"] },
    "generatedAt": { "type": "number", "minimum": 0 },
    "updatedAt": { "type": ["number", "null"], "minimum": 0 },
    "visibility": { "enum": ["public", "private"] },
    "state": {
      "type": "object",
      "required": ["locations", "times", "cast", "objects", "conditions", "threads"],
      "properties": {
        "locations": { "type": "array", "items": { "$ref": "#/$defs/location" } },
        "times": { "type": "array", "items": { "$ref": "#/$defs/time" } },
        "cast": { "type": "array", "items": { "$ref": "#/$defs/cast" } },
        "objects": { "type": "array", "items": { "$ref": "#/$defs/object" } },
        "conditions": { "type": "array", "items": { "$ref": "#/$defs/condition" } },
        "threads": { "type": "array", "items": { "$ref": "#/$defs/thread" } }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "entity": {
      "type": "object",
      "required": ["namespace", "id", "kind"],
      "properties": {
        "namespace": { "type": "string", "minLength": 1 },
        "id": { "type": "string", "minLength": 1 },
        "kind": { "enum": ["character", "persona", "npc", "object", "thread"] }
      },
      "additionalProperties": false
    },
    "subject": {
      "oneOf": [
        {
          "type": "object",
          "required": ["kind"],
          "properties": { "kind": { "const": "scene" } },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["kind", "actor"],
          "properties": {
            "kind": { "const": "actor" },
            "actor": { "$ref": "#/$defs/entity" }
          },
          "additionalProperties": false
        }
      ]
    },
    "provenance": {
      "type": "object",
      "required": ["extensionId", "method", "observedAt"],
      "properties": {
        "extensionId": { "type": "string", "minLength": 1 },
        "method": { "type": "string", "minLength": 1 },
        "observedAt": { "type": "number", "minimum": 0 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "derivedFrom": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["endpoint", "chatId", "revision"],
            "properties": {
              "endpoint": { "type": "string", "minLength": 3 },
              "chatId": { "type": "string", "minLength": 1 },
              "revision": { "type": "integer", "minimum": 0 }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "location": {
      "type": "object",
      "required": ["id", "subject", "label", "provenance"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "subject": { "$ref": "#/$defs/subject" },
        "label": { "type": "string", "minLength": 1 },
        "provenance": { "$ref": "#/$defs/provenance" }
      }
    },
    "time": {
      "type": "object",
      "required": ["id", "subject", "clock", "date", "time", "day", "hour", "running", "timezone", "provenance"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "subject": { "$ref": "#/$defs/subject" },
        "clock": { "type": "string", "minLength": 1 },
        "date": { "type": ["string", "null"] },
        "time": { "type": ["string", "null"] },
        "day": { "type": ["integer", "null"], "minimum": 0 },
        "hour": { "type": ["integer", "null"], "minimum": 0, "maximum": 23 },
        "running": { "type": ["boolean", "null"] },
        "timezone": { "type": ["string", "null"] },
        "provenance": { "$ref": "#/$defs/provenance" }
      }
    },
    "cast": {
      "type": "object",
      "required": ["id", "actor", "links", "name", "aliases", "present", "confirmed", "publicStance", "provenance"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "actor": { "$ref": "#/$defs/entity" },
        "links": { "type": "array", "items": { "$ref": "#/$defs/entity" } },
        "name": { "type": "string", "minLength": 1 },
        "aliases": { "type": "array", "items": { "type": "string" } },
        "present": { "type": "boolean" },
        "confirmed": { "type": "boolean" },
        "publicStance": { "type": "string" },
        "provenance": { "$ref": "#/$defs/provenance" }
      }
    },
    "object": {
      "type": "object",
      "required": ["id", "object", "name", "state", "provenance"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "object": { "$ref": "#/$defs/entity" },
        "name": { "type": "string", "minLength": 1 },
        "state": { "type": "string" },
        "provenance": { "$ref": "#/$defs/provenance" }
      }
    },
    "condition": {
      "type": "object",
      "required": ["id", "subject", "kind", "label", "attributes", "provenance"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "subject": { "$ref": "#/$defs/subject" },
        "kind": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "attributes": {
          "type": "object",
          "additionalProperties": { "type": ["string", "number", "boolean", "null"] }
        },
        "provenance": { "$ref": "#/$defs/provenance" }
      }
    },
    "thread": {
      "type": "object",
      "required": ["id", "thread", "label", "status", "summary", "provenance"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "thread": { "$ref": "#/$defs/entity" },
        "label": { "type": "string", "minLength": 1 },
        "status": { "enum": ["active", "resolved", "abandoned", "unknown"] },
        "summary": { "type": "string" },
        "provenance": { "$ref": "#/$defs/provenance" }
      }
    }
  }
}
